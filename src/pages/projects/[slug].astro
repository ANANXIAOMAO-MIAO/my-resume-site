---
import ProjectDetailNavigator from "../../components/ProjectDetailNavigator.astro";
import ProjectGallery from "../../components/ProjectGallery.astro";
import { projects } from "../../content/projects";
import { profile } from "../../content/profile";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout title={`${project.title} · ${profile.name}`} description={project.summary}>
  <header class="site-header detail-header">
    <a href="/" class="brand">← 返回首页</a>
    <nav aria-label="Project navigation">
      <a href="/#projects">Projects</a>
      <a href="/#contact">Contact</a>
    </nav>
  </header>

  <main>
    <article class="project-detail section-shell">
      <div class="detail-hero">
        <div>
          <p class="eyebrow">Project Detail</p>
          <h1>{project.title}</h1>
          <p class="hero-intro">{project.summary}</p>
          {
            project.links.length > 0 && !project.embed && (
              <a class="text-link" href={project.links[0].href} target="_blank" rel="noreferrer">
                {project.links[0].label} →
              </a>
            )
          }
          <div class="tag-row">
            {project.tags.map((tag) => <span>{tag}</span>)}
          </div>
        </div>
        <aside class="detail-meta">
          <div>
            <span>Time</span>
            <strong>{project.period}</strong>
          </div>
          <div>
            <span>Role</span>
            <strong class="experience-detail-role">{project.role}</strong>
          </div>
          {
            project.links.length > 0 && !project.embed && (
              <div>
                <span>Links</span>
                {project.links.map((link) => (
                  <a href={link.href} target="_blank" rel="noreferrer">
                    {link.label}
                  </a>
                ))}
              </div>
            )
          }
        </aside>
      </div>

      <figure class="detail-cover">
        <img src={project.cover} alt={`${project.title} 封面`} />
      </figure>

      <ProjectDetailNavigator project={project} />

      {
        project.embed ? (
          <section class="detail-embed">
            <p class="eyebrow">Live Demo</p>
            <h2>{project.embed.title}</h2>
            <div class="dify-embed-frame">
              <iframe
                src={project.embed.iframeSrc}
                title={project.embed.title}
                loading="lazy"
                allow="microphone"
              />
            </div>
          </section>
        ) : (
          <section class="detail-gallery">
            <p class="eyebrow">Screens</p>
            <h2>项目截图与材料</h2>
            <ProjectGallery images={project.gallery} title={project.title} />
          </section>
        )
      }
    </article>
  </main>
</BaseLayout>
