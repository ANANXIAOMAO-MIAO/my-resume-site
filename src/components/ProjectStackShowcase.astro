---
import type { Project } from "../content/projects";

type Props = {
  projects: Project[];
};

const { projects } = Astro.props;
const lastIndex = projects.length - 1;
---

<div class="project-showcase" data-project-showcase>
  <div class="project-stack" data-project-stack>
    {
      projects.map((project, index) => (
        <a
          class:list={[
            "project-stack-card",
            index === 0 && "is-active",
            index === lastIndex && "is-back-left",
            index === 1 && "is-back-right",
            index > 1 && index !== lastIndex && "is-hidden",
          ]}
          data-project-index={index}
          href={`/projects/${project.slug}/`}
          aria-hidden={index === 0 ? "false" : "true"}
          tabindex={index === 0 ? 0 : -1}
        >
          <div class="project-stack-media">
            <img src={project.cover} alt={`${project.title} 封面`} loading="lazy" />
          </div>
          <div class="project-stack-copy">
            <p class="meta">{project.period} · {project.role}</p>
            <h3>{project.title}</h3>
            <p>{project.summary}</p>
          </div>
        </a>
      ))
    }
  </div>

  <nav class="project-nav-box" role="tablist" aria-label="项目导航">
    {
      projects.map((project, index) => (
        <button
          type="button"
          class:list={["project-nav-button", { active: index === 0 }]}
          data-project-index={index}
          role="tab"
          aria-selected={index === 0 ? "true" : "false"}
          tabindex={index === 0 ? 0 : -1}
        >
          {project.title}
        </button>
      ))
    }
  </nav>
</div>

<script>
  const showcases = document.querySelectorAll<HTMLElement>("[data-project-showcase]");

  showcases.forEach((showcase) => {
    const buttons = Array.from(showcase.querySelectorAll<HTMLButtonElement>(".project-nav-button"));
    const cards = Array.from(showcase.querySelectorAll<HTMLAnchorElement>(".project-stack-card"));

    if (buttons.length === 0 || cards.length === 0) return;

    const total = cards.length;

    const setActiveProject = (nextIndex: number) => {
      const prevIndex = (nextIndex - 1 + total) % total;
      const nextCardIndex = (nextIndex + 1) % total;

      buttons.forEach((button, index) => {
        const isActive = index === nextIndex;
        button.classList.toggle("active", isActive);
        button.setAttribute("aria-selected", String(isActive));
        button.tabIndex = isActive ? 0 : -1;
      });

      cards.forEach((card, index) => {
        card.classList.remove("is-active", "is-back-left", "is-back-right", "is-hidden");

        if (index === nextIndex) {
          card.classList.add("is-active");
          card.setAttribute("aria-hidden", "false");
          card.tabIndex = 0;
        } else if (index === prevIndex) {
          card.classList.add("is-back-left");
          card.setAttribute("aria-hidden", "true");
          card.tabIndex = -1;
        } else if (index === nextCardIndex) {
          card.classList.add("is-back-right");
          card.setAttribute("aria-hidden", "true");
          card.tabIndex = -1;
        } else {
          card.classList.add("is-hidden");
          card.setAttribute("aria-hidden", "true");
          card.tabIndex = -1;
        }
      });
    };

    buttons.forEach((button, index) => {
      button.addEventListener("click", () => {
        setActiveProject(index);
      });
    });

    cards.forEach((card) => {
      card.addEventListener("click", (event) => {
        if (!card.classList.contains("is-active")) {
          event.preventDefault();
        }
      });
    });
  });
</script>
