---
import type { Project } from "../content/projects";

type Props = {
  project: Project;
  compact?: boolean;
};

const { project, compact = false } = Astro.props;
---

<article class:list={["project-card", { compact }]}>
  {
    !compact && (
      <a class="project-media" href={`/projects/${project.slug}/`} aria-label={`查看 ${project.title}`}>
        <img src={project.cover} alt={`${project.title} 封面`} loading="lazy" />
      </a>
    )
  }
  <div class="project-copy">
    <p class="meta">{project.period} · {project.role}</p>
    <h3>
      <a href={`/projects/${project.slug}/`}>{project.title}</a>
    </h3>
    <p>{project.summary}</p>
    <div class="tag-row compact">
      {project.tags.map((tag) => <span>{tag}</span>)}
    </div>
    <a class="text-link" href={`/projects/${project.slug}/`}>查看详情 →</a>
  </div>
</article>
