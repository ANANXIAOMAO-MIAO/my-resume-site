---
import type { TimelineExperience } from "../content/experiences";

type Props = {
  experiences: TimelineExperience[];
};

const { experiences } = Astro.props;
const lastIndex = experiences.length - 1;
---

<div class="experience-carousel" data-experience-carousel>
  <div class="experience-timeline-nav" role="tablist" aria-label="工作经历时间轴">
    {
      experiences.map((experience, index) => (
        <button
          type="button"
          class:list={["experience-timeline-button", { active: index === 0 }]}
          data-experience-index={index}
          role="tab"
          aria-selected={index === 0 ? "true" : "false"}
          aria-controls={`experience-panel-${index}`}
          tabindex={index === 0 ? "0" : "-1"}
        >
          <span class="experience-node" aria-hidden="true" />
          <span class="experience-node-copy">
            <span>{experience.period}</span>
            <strong>{experience.organization}</strong>
            <em>{experience.role}</em>
          </span>
        </button>
      ))
    }
  </div>

  <div class="experience-stack" data-experience-stack>
    {
      experiences.map((experience, index) => (
        <article
          id={`experience-panel-${index}`}
          class:list={[
            "experience-panel",
            index === 0 && "is-active",
            index === lastIndex && "is-prev",
            index === 1 && "is-next",
            index > 1 && index !== lastIndex && "is-hidden",
          ]}
          data-experience-panel={index}
          role="tabpanel"
          aria-hidden={index === 0 ? "false" : "true"}
        >
          <div class="experience-panel-body">
            <p class="card-label">Selected Experience</p>
            <h3>{experience.organization}</h3>
            <p class="experience-detail-role">{experience.role}</p>
            <p class="meta">{experience.period}</p>
            <p class="experience-detail-summary">{experience.summary}</p>
            <p class="experience-detail-highlights">{experience.highlights}</p>
          </div>
        </article>
      ))
    }
  </div>
</div>

<script>
  const carousels = document.querySelectorAll<HTMLElement>("[data-experience-carousel]");

  const syncExperienceStackHeight = (stack: HTMLElement, panels: HTMLElement[]) => {
    stack.classList.add("is-measuring");
    panels.forEach((panel) => panel.classList.add("is-measuring"));

    const maxHeight = panels.reduce((height, panel) => Math.max(height, panel.offsetHeight), 0);

    panels.forEach((panel) => panel.classList.remove("is-measuring"));
    stack.classList.remove("is-measuring");

    if (maxHeight > 0) {
      stack.style.setProperty("--experience-panel-height", `${maxHeight}px`);
    }
  };

  carousels.forEach((carousel) => {
    const buttons = Array.from(
      carousel.querySelectorAll<HTMLButtonElement>("[data-experience-index]"),
    );
    const panels = Array.from(carousel.querySelectorAll<HTMLElement>("[data-experience-panel]"));
    const stack = carousel.querySelector<HTMLElement>("[data-experience-stack]");

    if (!stack || buttons.length === 0 || panels.length === 0) return;

    const total = panels.length;
    let activeIndex = 0;

    const setActiveExperience = (nextIndex: number) => {
      activeIndex = nextIndex;
      const prevIndex = (activeIndex - 1 + total) % total;
      const nextPanelIndex = (activeIndex + 1) % total;

      buttons.forEach((button, index) => {
        const isActive = index === activeIndex;
        button.classList.toggle("active", isActive);
        button.setAttribute("aria-selected", String(isActive));
        button.tabIndex = isActive ? 0 : -1;
      });

      panels.forEach((panel, index) => {
        panel.classList.remove("is-active", "is-prev", "is-next", "is-hidden");

        if (index === activeIndex) {
          panel.classList.add("is-active");
        } else if (index === prevIndex) {
          panel.classList.add("is-prev");
        } else if (index === nextPanelIndex) {
          panel.classList.add("is-next");
        } else {
          panel.classList.add("is-hidden");
        }

        panel.setAttribute("aria-hidden", String(index !== activeIndex));
      });
    };

    buttons.forEach((button, index) => {
      button.addEventListener("click", () => {
        setActiveExperience(index);
      });
    });

    const measureHeights = () => syncExperienceStackHeight(stack, panels);

    measureHeights();
    window.addEventListener("resize", measureHeights);
  });
</script>
